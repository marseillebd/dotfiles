[user]
    name = Marseille Bouchard Demko
    email = marseillebd@proton.me
[alias]
    st = status
    com = commit -a
    amend = commit -a --amend
    co = checkout
    hash = rev-parse HEAD
    graph = log --graph --exclude=issues --branches --oneline --decorate
    rollback = checkout --
    undo = restore
    unstage = restore --staged
    updiff = log --branches --not --remotes --oneline
    iss = !git-issue
[push]
    default = simple
[pull]
    rebase = false
[icdiff]
    options = --line-numbers
[init]
    defaultBranch = main
