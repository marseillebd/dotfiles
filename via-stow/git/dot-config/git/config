[user]
    name = Marseille Bouchard Demko
    email = marseillebd@proton.me
[alias]
    st = status
    com = commit -a
    amend = commit -a --amend
    co = checkout
    hash = rev-parse HEAD
    graph = log --graph --exclude=issues --branches --oneline --decorate
    rollback = checkout --
    undo = restore
    unstage = restore --staged
    updiff = log --branches --not --remotes --oneline
    iss = !git-issue
    touch = !touch $@ && git add
[push]
    default = simple
[pull]
    rebase = false
[icdiff]
    options = --line-numbers
[init]
    defaultBranch = main
[credential "https://github.com"]
	helper = 
	helper = !/run/current-system/sw/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/run/current-system/sw/bin/gh auth git-credential
