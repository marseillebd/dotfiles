[global_config]
  disable_mouse_paste = True
[keybindings]
  preferences = <Primary>less
[profiles]
  [[default]]
    audible_bell = True
    background_darkness = 0.85
    background_type = image
    background_image = /home/marseillebd/.local/share/wallpapers/galaxy-wallpaper-21.jpg
